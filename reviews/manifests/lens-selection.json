{
  "schema_version": "1.1",
  "id": "lens-selection-policy",
  "description": "Deterministic minimum lens selection. Matching is Unicode-normalized and case-insensitive, using phrase boundaries plus bounded co-occurrence rules where a single keyword is insufficient.",
  "clarification_question": "The supplied review input and target do not establish a review risk domain. Name the affected behavior or select lenses explicitly before reviewers are started.",
  "domains": [
    {
      "id": "user-facing-workflow",
      "lenses": ["test-strategy", "product-ux"],
      "phrases": [
        "user-facing", "user visible", "interaction flow", "screen", "dialog",
        "button", "form", "toast", "loading state", "empty state", "error state",
        "accessibility", "operator chooses", "customer workflow", "ui"
      ]
    },
    {
      "id": "stateful-workflow",
      "lenses": ["architecture", "implementation", "test-strategy"],
      "phrases": [
        "state transition", "state ownership", "stateful", "saved state", "save", "load",
        "restore", "delete", "reset", "defer", "deferred", "apply"
      ]
    },
    {
      "id": "shared-contract",
      "lenses": ["architecture", "implementation", "test-strategy"],
      "phrases": [
        "cross-module", "module boundary", "shared service", "shared engine", "shared utility",
        "api contract", "interface contract", "new abstraction", "dependency ordering"
      ]
    },
    {
      "id": "implementation-complexity",
      "lenses": ["implementation"],
      "phrases": [
        "multi-step", "implementation plan", "platform constraint", "sequencing risk",
        "tooling change", "compatibility handling"
      ]
    },
    {
      "id": "runtime-validation",
      "lenses": ["test-strategy"],
      "phrases": [
        "runtime validation", "regression coverage", "negative path", "edge case",
        "error handling", "validation command", "pass criteria", "fail criteria"
      ]
    },
    {
      "id": "migration-and-data",
      "lenses": ["implementation", "risk", "test-strategy", "data-model"],
      "phrases": [
        "persistence", "persisted", "saved record", "stored record", "schema change",
        "database", "storage contract", "migration", "backfill", "data integrity",
        "backward compatibility", "library feature", "history feature"
      ]
    },
    {
      "id": "operational-risk",
      "lenses": ["risk"],
      "phrases": [
        "rollback", "irreversible", "production failure", "blast radius", "kill switch",
        "race condition", "stale state", "rollout"
      ]
    },
    {
      "id": "security-boundary",
      "lenses": ["security"],
      "phrases": [
        "security", "privacy", "authorization", "authentication", "authn", "authz",
        "secret", "credential", "token", "trust boundary", "privilege", "injection",
        "ssrf", "rce", "path traversal", "untrusted input", "external payload",
        "outbound request", "redirect", "allowlist"
      ]
    },
    {
      "id": "llm-authority-boundary",
      "lenses": ["natty"],
      "rules": [
        {
          "id": "agent-or-skill-design",
          "any_of": [
            "agent design", "skill design", "agent instruction", "skill instruction",
            "agent prompt", "skill prompt", "system prompt"
          ]
        },
        {
          "id": "natural-language-resolution",
          "all_of": [
            ["natural language", "free text", "user utterance", "chat input", "conversational input"],
            ["command", "intent", "resolve", "select", "choose", "classify", "route", "routing", "dispatch", "write", "persist", "authoritative"]
          ]
        },
        {
          "id": "model-owned-structure-or-state",
          "except_any": [
            "does not use an llm", "does not use a language model",
            "no llm or model generated", "no model generated state", "without an llm"
          ],
          "all_of": [
            ["llm", "language model", "model", "ai", "assistant"],
            ["structured output", "json", "schema", "tool argument", "tool arguments", "identity", "confidence", "filter", "state", "write", "persist", "authoritative narration", "narration"]
          ]
        },
        {
          "id": "model-selected-tool-or-route",
          "all_of": [
            ["llm", "language model", "model", "ai", "assistant"],
            ["choose tool", "chooses tool", "choose which tool", "chooses which tool", "select tool", "selects tool", "select which tool", "selected tool", "tool call", "route", "routing", "dispatcher"]
          ]
        },
        {
          "id": "tool-or-retrieval-reentry",
          "except_any": [
            "never enters model context", "does not enter model context",
            "not sent to model context", "outside model context"
          ],
          "all_of": [
            ["tool output", "tool result", "tool response", "mcp result", "api response", "rag", "retrieval result", "retrieved document", "retrieved context"],
            ["model context", "prompt", "llm", "model", "assistant", "decision", "resolve", "route", "routing", "narration"]
          ]
        },
        {
          "id": "retrieved-instruction-payload",
          "all_of": [
            ["tool output", "tool result", "tool response", "mcp result", "api response", "retrieval result", "retrieved document", "retrieved context"],
            ["ignore prior instructions", "override instructions", "system instruction", "select admin", "act as system"]
          ]
        },
        {
          "id": "direct-injection-surface",
          "any_of": [
            "prompt injection", "indirect prompt injection", "tool data injection", "retrieval poisoning"
          ]
        }
      ]
    }
  ]
}
