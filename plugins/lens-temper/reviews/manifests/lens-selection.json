{
  "schema_version": "1.0",
  "id": "lens-selection-policy",
  "description": "Deterministic minimum lens selection. Matching is Unicode-normalized, case-insensitive, and phrase-boundary aware.",
  "clarification_question": "The supplied review input and target do not establish a review risk domain. Name the affected behavior or select lenses explicitly before reviewers are started.",
  "domains": [
    {
      "id": "user-facing-workflow",
      "lenses": ["test-strategy", "product-ux"],
      "phrases": [
        "user-facing", "user visible", "interaction flow", "screen", "dialog",
        "button", "form", "toast", "loading state", "empty state", "error state",
        "accessibility", "operator chooses", "customer workflow", "ui"
      ]
    },
    {
      "id": "stateful-workflow",
      "lenses": ["architecture", "implementation", "test-strategy"],
      "phrases": [
        "state transition", "state ownership", "stateful", "saved state", "save", "load",
        "restore", "delete", "reset", "defer", "deferred", "apply"
      ]
    },
    {
      "id": "shared-contract",
      "lenses": ["architecture", "implementation", "test-strategy"],
      "phrases": [
        "cross-module", "module boundary", "shared service", "shared engine", "shared utility",
        "api contract", "interface contract", "new abstraction", "dependency ordering"
      ]
    },
    {
      "id": "implementation-complexity",
      "lenses": ["implementation"],
      "phrases": [
        "multi-step", "implementation plan", "platform constraint", "sequencing risk",
        "tooling change", "compatibility handling"
      ]
    },
    {
      "id": "runtime-validation",
      "lenses": ["test-strategy"],
      "phrases": [
        "runtime validation", "regression coverage", "negative path", "edge case",
        "error handling", "validation command", "pass criteria", "fail criteria"
      ]
    },
    {
      "id": "migration-and-data",
      "lenses": ["implementation", "risk", "test-strategy", "data-model"],
      "phrases": [
        "persistence", "persisted", "saved record", "stored record", "schema change",
        "database", "storage contract", "migration", "backfill", "data integrity",
        "backward compatibility", "library feature", "history feature"
      ]
    },
    {
      "id": "operational-risk",
      "lenses": ["risk"],
      "phrases": [
        "rollback", "irreversible", "production failure", "blast radius", "kill switch",
        "race condition", "stale state", "rollout"
      ]
    },
    {
      "id": "security-boundary",
      "lenses": ["security"],
      "phrases": [
        "security", "privacy", "authorization", "authentication", "authn", "authz",
        "secret", "credential", "token", "trust boundary", "privilege", "injection",
        "ssrf", "rce", "path traversal", "untrusted input", "external payload",
        "outbound request", "redirect", "allowlist"
      ]
    },
    {
      "id": "llm-authority-boundary",
      "lenses": ["natty"],
      "phrases": [
        "agent design", "skill design", "agent instruction", "skill instruction",
        "natural language command", "free text", "user utterance", "intent classification",
        "structured model output", "llm generated", "model generated", "model selected tool",
        "model selected route", "tool routing", "mcp tool", "tool returned data",
        "rag result", "retrieval augmented", "llm derived identity", "llm confidence",
        "model confidence", "llm derived filter", "llm derived state", "model generated write",
        "authoritative narration", "prompt injection", "disambiguation"
      ]
    }
  ]
}
