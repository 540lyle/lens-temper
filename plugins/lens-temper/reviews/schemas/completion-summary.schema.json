{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LensTemper Completion Summary",
  "type": "object",
  "required": [
    "schema_version",
    "run_mode",
    "run_scope",
    "target_path",
    "target_revision",
    "claim_flags",
    "summary_text"
  ],
  "properties": {
    "schema_version": { "const": 3 },
    "run_mode": {
      "enum": ["full", "inline", "advisory"]
    },
    "run_scope": {
      "enum": ["core_profile", "selected_lenses"]
    },
    "core_profile_id": { "type": "string", "minLength": 1 },
    "required_lens_ids": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "completed_lens_ids": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "core_gate_passed": { "type": "boolean" },
    "target_path": { "type": "string" },
    "target_revision": { "type": "string" },
    "review_input_revision": { "type": "string" },
    "claim_flags": {
      "type": "object",
      "required": ["completion", "lock_state", "all_5_lockable", "review_complete"],
      "properties": {
        "completion": { "type": "boolean" },
        "lock_state": { "type": "boolean" },
        "all_5_lockable": { "type": "boolean" },
        "review_complete": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "summary_text": { "type": "string" }
  },
  "additionalProperties": true,
  "allOf": [
    {
      "if": { "properties": { "run_mode": { "const": "full" } } },
      "then": {
        "required": ["review_input_revision"]
      }
    },
    {
      "if": { "properties": { "run_scope": { "const": "core_profile" } } },
      "then": {
        "required": ["core_profile_id", "required_lens_ids", "completed_lens_ids", "core_gate_passed"]
      }
    }
  ]
}
