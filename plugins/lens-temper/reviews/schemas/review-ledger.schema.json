{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LensTemper Review Ledger",
  "type": "object",
  "required": [
    "schema_version",
    "pass_id",
    "target_path",
    "target_revision",
    "status",
    "run_mode",
    "run_scope",
    "execution_mode",
    "selected_lenses",
    "current_review_record_ids",
    "superseded_review_record_ids",
    "synthesis_record_ids",
    "archive_paths",
    "artifact_visibility",
    "completion_validation",
    "review_record_artifacts",
    "synthesis_record_artifacts"
  ],
  "properties": {
    "schema_version": { "const": 3 },
    "pass_id": { "type": "string" },
    "target_path": { "type": "string" },
    "target_revision": { "type": "string" },
    "review_input_path": { "type": "string" },
    "review_input_revision": { "type": "string" },
    "lens_selection_path": { "type": "string" },
    "lens_selection_revision": { "type": "string" },
    "status": {
      "enum": ["active", "completed", "error", "superseded", "stale"]
    },
    "run_mode": {
      "enum": ["full", "inline", "advisory"]
    },
    "run_scope": {
      "enum": ["core_profile", "selected_lenses"]
    },
    "core_profile_id": { "type": "string", "minLength": 1 },
    "required_lens_ids": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "completed_lens_ids": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true,
      "readOnly": true
    },
    "core_gate_passed": { "type": "boolean", "readOnly": true },
    "execution_mode": {
      "enum": ["fresh_spawned_lens_reviewers", "fresh_spawned_orchestrator", "manual_or_imported"]
    },
    "events_path": { "type": "string" },
    "selected_lenses": {
      "type": "array",
      "items": { "type": "string" }
    },
    "current_review_record_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "superseded_review_record_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "synthesis_record_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "archive_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifact_visibility": {
      "enum": ["public_safe", "private_local_only"]
    },
    "completion_validation": {
      "type": "object",
      "readOnly": true,
      "required": [
        "validator_name",
        "validator_contract_version",
        "passed",
        "validated_review_record_ids",
        "failures"
      ],
      "properties": {
        "validator_name": { "type": "string" },
        "validator_contract_version": { "type": "string" },
        "passed": { "type": "boolean" },
        "validated_review_record_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "validated_synthesis_record_id": { "type": "string" },
        "failures": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "claim_type": { "type": "string" },
              "artifact_path": { "type": "string" },
              "field": { "type": "string" },
              "reason": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "review_record_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["record_id", "artifact_path"],
        "properties": {
          "record_id": { "type": "string" },
          "artifact_path": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "synthesis_record_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["record_id", "artifact_path"],
        "properties": {
          "record_id": { "type": "string" },
          "artifact_path": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true,
  "allOf": [
    {
      "if": {
        "properties": {
          "run_mode": { "const": "full" }
        }
      },
      "then": {
        "required": ["review_input_path", "review_input_revision", "lens_selection_path", "lens_selection_revision"]
      }
    },
    {
      "if": {
        "properties": {
          "run_scope": { "const": "core_profile" }
        }
      },
      "then": {
        "required": ["core_profile_id", "required_lens_ids", "completed_lens_ids", "core_gate_passed"]
      }
    },
    {
      "if": {
        "properties": {
          "execution_mode": { "const": "fresh_spawned_orchestrator" }
        }
      },
      "then": {
        "required": ["events_path"]
      }
    }
  ]
}
